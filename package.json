{
  "name": "n8n-nodes-5day",
  "version": "0.1.0",
  "description": "Project management tool",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Raj Patel",
    "email": "prax47099@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/n8n-nodes-5day.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.18.0",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/FiveDayApi.credentials.js",
      "dist/credentials/FiveDayOAuth2Api.credentials.js",
      "dist/credentials/GithubIssuesApi.credentials.js",
      "dist/credentials/GithubIssuesOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Fiveday/Fiveday.node.js",
      "dist/nodes/GithubIssues/GithubIssues.node.js",
      "dist/nodes/Example/Example.node.js"
    ]
  },
  "dependencies": {
    "change-case": "4.1.2"
  },
  "overrides": {
    "@n8n/node-cli": {
      "change-case": "4.1.2"
    }
  }
